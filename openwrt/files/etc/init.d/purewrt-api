#!/bin/sh /etc/rc.common
# Optional procd service for the PureWRT HTTP/JSON API daemon.
#
# Most installs don't need this — the CLI (`purewrt analyze` / `apply` /
# `doctor` / `mihomo-select`) covers the same surface and runs on demand
# via rpcd. The persistent HTTP server is useful when LuCI panels want to
# stream live data (E.1 SSE, J.* live traffic) or when external tooling
# scrapes `/status` and `/metrics`.
#
# Runs as the dedicated `purewrt` system user (created by uci-defaults) —
# never as root. The HTTP server is read-mostly (Status / Analyze). Bind
# addresses come from the `api_listen` UCI list (default 0.0.0.0:8787 —
# all interfaces; OpenWrt's firewall still blocks WAN input).

USE_PROCD=1
START=96
STOP=10

start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/purewrt-api
    procd_set_param user purewrt
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

reload_service() {
    stop
    start
}

service_triggers() {
    procd_add_reload_trigger purewrt
}
