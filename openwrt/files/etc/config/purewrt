config main 'settings'
    option config_version '1'
    option enabled '1'
    option workdir '/etc/purewrt'
    option runtime_dir '/tmp/purewrt'
    option dnsmasq_include_dir ''
    option mihomo_bin '/usr/bin/mihomo'
    option mihomo_config '/etc/purewrt/generated/mihomo.yaml'
    option external_controller '127.0.0.1:9090'
    option secret 'auto-generated-secret'
    option dns_backend 'dnsmasq'
    option firewall_backend 'nftables'
    option fwmark '0x1'
    option fwmark_mask '0xff'
    option route_table '100'
    option ip_rule_priority '100'
    option ipv6 '1'
    option fake_ip '0'
    option sniffer '0'
    option dns_listen '127.0.0.1:7874'
    option auto_reload '1'
    option safe_apply '1'
    option rollback_on_fail '1'
    option mihomo_channel 'alpha'
    option mihomo_release_api 'https://api.github.com/repos/MetaCubeX/mihomo/releases/tags/Prerelease-Alpha'
    option mihomo_version ''
    option mihomo_arch ''
    option mihomo_asset_url ''
    option mihomo_sha256_url ''
    option update_via_proxy '0'
    option update_proxy_url 'http://127.0.0.1:7890'
    option update_concurrency '2'
    option auto_update_enabled '1'
    option auto_update_cron '17 */6 * * *'
    option reload_after_update '1'
    option backup_retention '3'
    option background_updates '1'
    option boot_update_delay '0'
    option update_nice '19'
    option update_ionice_class '3'
    option update_ionice_level '7'
    option dashboard_enabled '1'
    option dashboard_listen '0.0.0.0:9090'
    option dashboard_path '/etc/purewrt/dashboard'
    option dashboard_url 'https://github.com/MetaCubeX/metacubexd/archive/refs/heads/gh-pages.zip'
    option dashboard_name 'metacubexd'
    option resource_profile 'standard'
    option bootstrap_doh_enabled '1'
    list bootstrap_doh_resolver 'https://1.1.1.1/dns-query'
    list bootstrap_doh_resolver 'https://1.0.0.1/dns-query'
    list bootstrap_doh_resolver 'https://8.8.8.8/dns-query'
    list bootstrap_doh_resolver 'https://9.9.9.9/dns-query'
    list bootstrap_doh_resolver 'https://94.140.14.14/dns-query'
    list bootstrap_doh_resolver 'https://94.140.15.15/dns-query'
    list bootstrap_doh_resolver 'https://194.242.2.2/dns-query'
    list bootstrap_doh_resolver 'https://77.88.8.1/dns-query'
    option bootstrap_doh_timeout_ms '8000'
    option bootstrap_health_gate '0'
    option zapret_upstream_config_path ''
    option bootstrap_proxy_fallback '1'
    option bootstrap_tls_fingerprint 'browser'
    option ipv6_mode 'auto'
    option ipv6_reject_when_off '0'
    option router_output_proxy '1'
    option cgroup_v2_path 'services/mihomo'
    option log_level 'warn'
    option metrics_enabled '0'
    option mihomo_geodata_enabled '0'
    option rule_dedup_mode 'auto'

config dns 'dns'
    option enabled '1'
    option backend 'dnsmasq'
    option upstream_mode 'mihomo'
    option hijack_lan_dns '1'
    option block_dot '1'
    option block_doh3 '1'
    option block_doq '1'
    option doh_policy 'proxy'
    option listen '127.0.0.1:7874'
    option fake_ip '0'
    option enhanced_mode 'normal'
    option proxy_group_type 'url-test'
    option proxy_filter ''
    option proxy_exclude_filter ''
    option proxy_strategy 'sticky-sessions'
    list doh_upstream 'https://dns.google/dns-query'
    list doh_upstream 'https://cloudflare-dns.com/dns-query'
    list doh_upstream 'https://dns.quad9.net/dns-query'
    list udp_upstream '1.1.1.1'
    list udp_upstream '8.8.8.8'
    list udp_upstream '9.9.9.9'

config mwan3 'mwan3'
    option mode 'coexist'
    option detect '1'
    option mmx_mask_auto '1'
    option mwan3_mask ''
    option purewrt_mark '0x1'
    option purewrt_mask '0xff'
    option rule_priority '100'
    option integrated_rules '0'

config zapret_profile 'wan'
    option name 'wan'
    option enabled '0'
    option network 'auto'
    option device ''
    option interface_mode 'mwan3_members'
    list interface 'wan'
    option fwmark '0x40000000'
    option nfqws_bin '/usr/libexec/zapret/nfqws2'
    option tpws_bin '/usr/libexec/zapret/tpws'
    option lua_bundle_dir '/usr/libexec/zapret/lua'

config zapret_strategy 'youtube_tcp'
    option name 'youtube_tcp'
    option enabled '0'
    option profile 'wan'
    option preset 'youtube_tcp'
    option queue_num '200'
    list protocols 'tcp'
    option tcp_ports '443'
    option tcp_pkt_out '15'
    option tcp_pkt_in '6'
    option fake_dir '/usr/libexec/zapret/files/fake'
    option params '--filter-tcp=443 --payload=tls_client_hello --lua-desync=fake:blob=fake_default_tls --lua-desync=multisplit'

config zapret_strategy 'youtube_quic'
    option name 'youtube_quic'
    option enabled '0'
    option profile 'wan'
    option preset 'youtube_quic'
    option queue_num '201'
    list protocols 'udp'
    option udp_ports '443'
    option udp_pkt_out '9'
    option udp_pkt_in '0'
    option fake_dir '/usr/libexec/zapret/files/fake'
    option params '--filter-udp=443 --dpi-desync=fake --dpi-desync-repeats=6'

config section 'media'
    option enabled '1'
    option action 'proxy'
    option tproxy_port '7894'
    option proxy_group 'Media'
    option proxy_group_type 'url-test'
    option proxy_filter ''
    option proxy_exclude_filter ''
    option proxy_strategy 'sticky-sessions'
    option export_openwrt '1'
    option export_mihomo '1'
    option ipv4_enabled '1'
    option ipv6_enabled '1'
    option priority '10'
    option udp_mode 'proxy'

config section 'ai'
    option enabled '1'
    option action 'proxy'
    option tproxy_port '7895'
    option proxy_group 'AI'
    option proxy_group_type 'url-test'
    option proxy_filter ''
    option proxy_exclude_filter ''
    option proxy_strategy 'sticky-sessions'
    option export_openwrt '1'
    option export_mihomo '1'
    option ipv4_enabled '1'
    option ipv6_enabled '1'
    option priority '20'
    option udp_mode 'proxy'

config section 'common'
    option enabled '1'
    option action 'proxy'
    option tproxy_port '7893'
    option proxy_group 'Common'
    option proxy_group_type 'url-test'
    option proxy_filter ''
    option proxy_exclude_filter ''
    option proxy_strategy 'sticky-sessions'
    option export_openwrt '1'
    option export_mihomo '1'
    option ipv4_enabled '1'
    option ipv6_enabled '1'
    option priority '30'
    option udp_mode 'proxy'

config bypass 'bypass'
