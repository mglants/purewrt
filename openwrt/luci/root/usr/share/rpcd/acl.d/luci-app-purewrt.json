{
  "luci-app-purewrt": {
    "description": "Grant access to PureWRT",
    "read": {
      "ubus": {
        "purewrt": [
          "status",
          "statistics",
          "rule_provider_status",
          "analyze",
          "preview",
          "classify",
          "check",
          "logs",
          "mihomo_config",
          "mihomo_check_update",
          "zapret_check_status",
          "zapret_autotune_status",
          "doctor_warnings",
          "inspect_ipv6",
          "resolvers_probe",
          "blocking_heuristics",
          "zapret_compiled_opt",
          "subscription_expiry",
          "mihomo_traffic_sample",
          "config_state",
          "update_status",
          "dpi_check_status",
          "client_traffic_status",
          "ipdb_status",
          "ipdb_update_status",
          "ipdb_asn",
          "zapret_installed",
          "ooni_installed",
          "ooni_status",
          "ooni_run_status",
          "tcpdump_installed",
          "mihomo_status",
          "mihomo_check_update_channel",
          "mihomo_install_release_status",
          "mihomo_mixin_get",
          "mihomo_mixin_preview",
          "apk_updates_available",
          "geo_list",
          "geo_default_sources",
          "config_export",
          "proxy_groups",
          "default_lists_catalog"
        ]
      },
      "uci": ["purewrt", "dhcp"],
      "file": {
        "/etc/purewrt/rulesets/*": [ "read" ]
      }
    },
    "write": {
      "ubus": {
        "purewrt": [
          "import",
          "override",
          "update",
          "update_rule_provider",
          "update_rule_provider_no_restart",
          "update_proxy_provider",
          "reload",
          "disable",
          "zapret_check",
          "zapret_check_start",
          "ooni_run_start",
          "mihomo_download",
          "zapret_restart",
          "geo_refresh",
          "zapret_autotune",
          "zapret_autotune_start",
          "update_start",
          "dpi_check_start",
          "client_traffic_start",
          "client_traffic_stop",
          "ipdb_update_start",
          "mihomo_install_release_start",
          "mihomo_revert_package",
          "mihomo_auto_update",
          "mihomo_mixin_set",
          "config_import",
          "proxy_select",
          "proxy_delay_test",
          "native_list_add",
          "wizard_reset"
        ]
      },
      "uci": ["purewrt"],
      "file": {
        "/etc/purewrt/rulesets/*": [ "write" ]
      }
    }
  }
}
